{
  "name": "@pickforge/picklab",
  "version": "0.1.1",
  "description": "Native app and Android emulator automation for AI coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pickforge/picklab.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/pickforge/picklab#readme",
  "bugs": "https://github.com/pickforge/picklab/issues",
  "keywords": [
    "mcp",
    "mcp-server",
    "android",
    "emulator",
    "xvfb",
    "automation",
    "testing",
    "ai-agents",
    "claude-code",
    "codex",
    "cursor",
    "flutter"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "picklab": "dist/picklab.js",
    "picklab-mcp": "dist/picklab-mcp.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "node -e \"const fs=require('node:fs');fs.copyFileSync('../../README.md','README.md');fs.copyFileSync('../../LICENSE','LICENSE')\"",
    "postpack": "node -e \"const fs=require('node:fs');fs.rmSync('README.md',{force:true});fs.rmSync('LICENSE',{force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "commander": "^14.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@pickforge/picklab-agent-installers": "*",
    "@pickforge/picklab-android": "*",
    "@pickforge/picklab-core": "*",
    "@pickforge/picklab-desktop-linux": "*",
    "@pickforge/picklab-mcp-server": "*"
  }
}
