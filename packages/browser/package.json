{
  "name": "@pickforge/picklab-browser",
  "version": "0.3.0",
  "private": true,
  "description": "Isolated headed Chrome/Chromium browser sessions for PickLab",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=23.0.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@pickforge/picklab-core": "*",
    "@pickforge/picklab-desktop-linux": "*",
    "chrome-devtools-mcp": "1.5.0"
  }
}
